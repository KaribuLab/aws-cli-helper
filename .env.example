AWS_AI_PROFILE=profile
AWS_AI_ASSUME_ROLE_ARN=role-arn
AWS_AI_MFA_SERIAL_ARN=mfa-serial-arn
# Opcional: duración de la sesión STS en segundos (900–43200). Por defecto 900 (15 min).
# AWS_AI_SESSION_DURATION_SECONDS=3600
AWS_REGION=us-east-2
CLI_DEBUG=true
AWS_AI_CACHE_PASSPHRASE=myS3c3tP@ssw0rD..
# Modo desatendido y token MFA: no van en .env por defecto. Actívalos por invocación:
#   docker run ... -e AWS_AI_UNATTENDED=true ...
#   docker run ... -e AWS_AI_MFA_TOKEN=123456 ...
